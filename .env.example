PORT=8787

# Resend
# Create a key in Resend and verify your sending domain first.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=TerrainDesk <demo@yourdomain.com>
DEMO_TO_EMAIL=you@yourdomain.com
ONBOARDING_TO_EMAIL=you@yourdomain.com

# Private admin panel
# Use a long random value and open /admin.html with this key.
ADMIN_API_KEY=change-this-to-a-long-random-admin-key

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# Stripe Checkout
# Create recurring Prices in Stripe for each plan.
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ESSENTIAL_AUD=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_OPERATIONS_AUD=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MULTI_CREW_AUD=price_xxxxxxxxxxxxxxxxxxxxx

# Stripe webhook endpoint:
# https://yourdomain.com/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Optional Xero OAuth
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://yourdomain.com/api/xero-callback

# Optional Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
